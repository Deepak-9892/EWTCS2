# EWTCS Environment Configuration
# Copy as: cp .env.example .env.local
# For detailed setup: see DATABASE_SETUP.md

# Required: Database Connection
DATABASE_URL=postgresql://postgres:password@localhost:5432/ewtcs

# Required: JWT Session Secret (minimum 32 characters)
SESSION_SECRET=your-secret-key-change-this-in-production-min-32-chars

# Required: Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required: Environment (development | staging | production)
NODE_ENV=development

# Optional: Delay Alert Threshold (milliseconds, default: 3 hours)
RED_ALERT_THRESHOLD_MS=10800000

# Real-time Updates Configuration (US-1.2)
NEXT_PUBLIC_REALTIME_ENABLED=true                    # Enable/disable real-time updates
NEXT_PUBLIC_REALTIME_POLLING_INTERVAL_MS=3000        # Poll every 3 seconds
NEXT_PUBLIC_REALTIME_RETRY_INTERVAL_MS=10000         # Retry after 10 seconds on error
NEXT_PUBLIC_REALTIME_MAX_RETRY_INTERVAL_MS=30000     # Max retry interval (exponential backoff cap)

# --------------------------------------------------------------------
# WARD ACCESS CONTROL (Migration 006)
# --------------------------------------------------------------------
# Ward-level access control is enforced via database (wards table).
# After running migrations, 3 default wards are created: EWA, EWB, EWC
# 
# Quick Setup (assigns all users/beds to Ward A):
#   psql -U postgres -d ewtcs -f scripts/setup-ward-assignments.sql
#
# Manual Setup Instructions:
# 1. Assign users to wards:
#    UPDATE users SET ward_id = (SELECT id FROM wards WHERE code = 'EWA') WHERE username = 'nurse1';
# 2. Assign beds to wards:
#    UPDATE beds SET ward_id = (SELECT id FROM wards WHERE code = 'EWA') WHERE bed_number LIKE 'ER-0%';
#
# Security Note: Nurses can only update beds in their assigned ward (IDOR protection).
# Admins/Supervisors have access to all wards.
# Without ward assignments, bed updates will show "permission denied" errors.

# Production Only: Encrypted Secrets
# DATABASE_URL_ENCRYPTED=ivhex:encryptedhex
# OPENAI_API_KEY_ENCRYPTED=ivhex:encryptedhex
# ENCRYPTION_KEY=your-64-char-hex-key

# Optional: OpenAI API Key (for AI reports)
# OPENAI_API_KEY=sk-your-openai-key

# --------------------------------------------------------------------
# ENVIRONMENT-SPECIFIC EXAMPLES
# --------------------------------------------------------------------
# 
# DEVELOPMENT (.env.local):
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ewtcs_dev
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NODE_ENV=development
# RED_ALERT_THRESHOLD_MS=10800000
#
# STAGING (.env.staging):
# DATABASE_URL=postgresql://user:pass@staging-host:5432/ewtcs_staging
# NEXT_PUBLIC_APP_URL=https://staging.yourdomain.com
# NODE_ENV=staging
# RED_ALERT_THRESHOLD_MS=10800000
#
# PRODUCTION (.env.production):
# DATABASE_URL_ENCRYPTED=ivhex:encryptedhex
# ENCRYPTION_KEY=your-64-character-hex-string
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
# NODE_ENV=production
# RED_ALERT_THRESHOLD_MS=10800000
#
# --------------------------------------------------------------------

# --------------------------------------------------------------------
# VALIDATION NOTES
# --------------------------------------------------------------------
# ✅ DATABASE_URL must be valid PostgreSQL connection string
# ✅ NEXT_PUBLIC_APP_URL must be valid URL
# ✅ RED_ALERT_THRESHOLD_MS must be positive integer
# ✅ Production requires DATABASE_URL_ENCRYPTED (plaintext not allowed)
# ✅ Encrypted variables require ENCRYPTION_KEY
# ✅ All required variables validated on startup
# ❌ Missing DATABASE_URL → Application will not start
# ❌ Invalid PostgreSQL URL → Application will not start
# ❌ Production without encryption → Application will not start
# --------------------------------------------------------------------

# For complete documentation:
# - Database Setup: See DATABASE_SETUP.md
# - Configuration: See CONFIGURATION.md
# - Contributing: See CONTRIBUTING.md
# - Architecture: See reports/FEATURE-FIRST-ARCHITECTURE-PLAN.md
