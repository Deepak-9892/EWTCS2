# ============================================================================
# EWTCS Environment Configuration
# ============================================================================
# Emergency Ward Bed Status Monitoring & AI Daily Report System
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env.local
# 2. Update DATABASE_URL with your PostgreSQL credentials
# 3. Generate a secure SESSION_SECRET (minimum 32 characters)
# 4. Update NEXT_PUBLIC_APP_URL if not using localhost:3000
# 5. Run: npm run setup (automated database setup)
#
# For detailed setup: See DATABASE_SETUP.md
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED: Database Configuration
# ----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/ewtcs

# ----------------------------------------------------------------------------
# REQUIRED: Security Configuration
# ----------------------------------------------------------------------------
# JWT Session Secret - MUST be at least 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-secret-key-change-this-in-production-min-32-chars

# ----------------------------------------------------------------------------
# REQUIRED: Application Configuration
# ----------------------------------------------------------------------------
# Public URL for the application (used for callbacks, links, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application port (default: 3000)
PORT=3000

# Environment mode (development | staging | production)
NODE_ENV=development

# Force HTTP -> HTTPS redirects at middleware layer in production.
# Keep true in staging/production. For local development, this is ignored unless NODE_ENV is staging/production.
FORCE_HTTPS=true

# Optional: HSTS preload token in response header.
# Keep this false unless you have submitted your domain to the HSTS preload list
# and validated requirements at https://hstspreload.org/
HSTS_PRELOAD=false

# ----------------------------------------------------------------------------
# OPTIONAL: Feature Configuration
# ----------------------------------------------------------------------------
# Delay Alert Threshold in milliseconds (default: 10800000 = 3 hours)
# When a patient stays in any stage longer than this, a red alert is shown
RED_ALERT_THRESHOLD_MS=10800000

# ----------------------------------------------------------------------------
# OPTIONAL: Real-time Updates Configuration (US-1.2)
# ----------------------------------------------------------------------------
# Real-time updates require Redis for WebSocket support
NEXT_PUBLIC_REALTIME_ENABLED=true
NEXT_PUBLIC_REALTIME_POLLING_INTERVAL_MS=3000
NEXT_PUBLIC_REALTIME_RETRY_INTERVAL_MS=10000
NEXT_PUBLIC_REALTIME_MAX_RETRY_INTERVAL_MS=30000

# ----------------------------------------------------------------------------
# OPTIONAL: Offline Cache Configuration (US-16.1 / US-16.2)
# ----------------------------------------------------------------------------
# US-16.1: Dashboard data is cached in localStorage on every successful fetch.
# When the browser loses network the last good snapshot is served automatically.
# US-16.2: Write operations are queued while offline and synced on reconnect.
#
# NEXT_PUBLIC_CACHE_ENABLED        — Set to 'false' to disable the cache entirely.
# NEXT_PUBLIC_CACHE_KEY            — localStorage key for the cache entry.
# NEXT_PUBLIC_CACHE_VERSION        — Bump this string when BedGridData schema changes
#                                    (old entries are discarded automatically).
# NEXT_PUBLIC_CACHE_EXPIRY_MS      — How long (ms) the cache is considered fresh.
#                                    Default: 300000 (5 minutes).
# NEXT_PUBLIC_CACHE_MAX_SIZE_BYTES — Maximum serialised cache size in bytes.
#                                    Default: 1572864 (1.5 MB).
NEXT_PUBLIC_CACHE_ENABLED=true
NEXT_PUBLIC_CACHE_KEY=ewtcs_bed_grid_cache
NEXT_PUBLIC_CACHE_VERSION=v1
NEXT_PUBLIC_CACHE_EXPIRY_MS=300000
NEXT_PUBLIC_CACHE_MAX_SIZE_BYTES=1572864

# OPTIONAL: AI Features (EPIC 9 — Daily AI Summary)
# ----------------------------------------------------------------------------
# Gemini API Key for AI-powered daily reports (EPIC 9: US-9.1, US-9.2, US-9.3)
# Get your free key at: https://aistudio.google.com/app/apikey
# Supports: gemini-2.5-flash (primary), gemini-2.0-flash-lite, gemini-2.0-flash (fallbacks)
# Without this key the AI summary feature returns a placeholder message instead of a real summary.
# GEMINI_API_KEY=your-gemini-api-key-here

# Timezone for daily aggregation cron (used for logging only; cron itself runs UTC)
# Example: Asia/Kolkata for IST, UTC for Universal
DAILY_SUMMARY_TIMEZONE=Asia/Kolkata

# ----------------------------------------------------------------------------
# PRODUCTION ONLY: Encrypted Secrets
# ----------------------------------------------------------------------------
# For production deployments, use encrypted environment variables
# instead of plaintext DATABASE_URL
# 
# DATABASE_URL_ENCRYPTED=ivhex:encryptedhex
# OPENAI_API_KEY_ENCRYPTED=ivhex:encryptedhex
# ENCRYPTION_KEY=your-64-character-hex-encryption-key
#
# Generate encryption key: node scripts/encrypt-secret.js
# See CONFIGURATION.md for encryption setup details

# ============================================================================
# ENVIRONMENT-SPECIFIC CONFIGURATION EXAMPLES
# ============================================================================

# ----------------------------------------------------------------------------
# LOCAL DEVELOPMENT (.env.local)
# ----------------------------------------------------------------------------
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/ewtcs_dev
# SESSION_SECRET=dev-secret-at-least-32-characters-long-please
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# PORT=3000
# NODE_ENV=development
# RED_ALERT_THRESHOLD_MS=10800000

# ----------------------------------------------------------------------------
# STAGING ENVIRONMENT (.env.staging)
# ----------------------------------------------------------------------------
# DATABASE_URL=postgresql://ewtcs_user:strong_password@staging-db.example.com:5432/ewtcs_staging
# SESSION_SECRET=staging-secret-key-at-least-32-characters-long
# NEXT_PUBLIC_APP_URL=https://staging.yourdomain.com
# PORT=3000
# NODE_ENV=staging
# RED_ALERT_THRESHOLD_MS=10800000

# ----------------------------------------------------------------------------
# PRODUCTION ENVIRONMENT (.env.production)
# ----------------------------------------------------------------------------
# Use encrypted secrets in production for security
# DATABASE_URL_ENCRYPTED=ivhex:your-encrypted-database-url-here
# ENCRYPTION_KEY=your-64-character-hex-encryption-key-here
# SESSION_SECRET=production-secret-key-minimum-32-characters-long
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
# PORT=3000
# NODE_ENV=production
# RED_ALERT_THRESHOLD_MS=10800000

# ============================================================================
# VALIDATION & TROUBLESHOOTING
# ============================================================================
#
# ✅ All required variables are validated on application startup
# ✅ Invalid configuration will prevent the app from starting
# ✅ See error messages in console for specific validation failures
#
# Common Issues:
# ❌ "DATABASE_URL is required" → Add DATABASE_URL to your .env.local
# ❌ "Invalid PostgreSQL URL" → Check DATABASE_URL format
# ❌ "SESSION_SECRET too short" → Must be at least 32 characters
# ❌ "Connection refused" → PostgreSQL server not running
# ❌ "Database does not exist" → Run: npm run db:migrate
#
# Validation checks performed:
# • DATABASE_URL must be valid PostgreSQL connection string
# • DATABASE_URL must be reachable (connection test)
# • SESSION_SECRET must be at least 32 characters
# • NEXT_PUBLIC_APP_URL must be valid URL format
# • RED_ALERT_THRESHOLD_MS must be positive integer (if provided)
# • Production mode requires encrypted secrets (no plaintext passwords)
#
