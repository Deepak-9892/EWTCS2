# Environment Configuration Template for EWTCS
# Emergency Ward Bed Status Monitoring and AI Daily Report System
#
# Copy this file to .env.local and fill in your actual values.
# Configuration is validated on startup.
# Supported environments: development, staging, production
# See CONFIGURATION.md for detailed setup instructions.

# --------------------------------------------------------------------
# REQUIRED: Database Configuration
# --------------------------------------------------------------------
# Option A: Plaintext connection string (allowed in development/staging)
DATABASE_URL=postgresql://username:password@localhost:5432/ewtcs

# Option B: Encrypted connection string (required in production)
# DATABASE_URL_ENCRYPTED=ivhex:encryptedhex
# ENCRYPTION_KEY=your-32-byte-master-key

# Notes:
# - Passwords must be URL-encoded if they contain special characters.
# - Never commit real credentials (use .env.local).

# --------------------------------------------------------------------
# REQUIRED: Application Configuration
# --------------------------------------------------------------------
# Public application URL (visible to clients)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------------------------------------------------------------
# REQUIRED: Environment Selection
# --------------------------------------------------------------------
# Node environment: development | staging | production
NODE_ENV=development

# --------------------------------------------------------------------
# OPTIONAL: Alert Configuration
# --------------------------------------------------------------------
# Hospital delay alert threshold in milliseconds
# Default: 10800000 (3 hours)
RED_ALERT_THRESHOLD_MS=10800000

# --------------------------------------------------------------------
# OPTIONAL: AI and Analytics Configuration
# --------------------------------------------------------------------
# Option A: Plaintext API key (allowed in development/staging)
# OPENAI_API_KEY=sk-your-api-key-here

# Option B: Encrypted API key (recommended)
# OPENAI_API_KEY_ENCRYPTED=ivhex:encryptedhex
# ENCRYPTION_KEY=your-32-byte-master-key

# --------------------------------------------------------------------
# Notes
# --------------------------------------------------------------------
# 1. Configuration is validated on application startup.
# 2. In production, DATABASE_URL must be encrypted.
# 3. Use environment-specific templates for multi-env setup.
# 4. For detailed documentation, see CONFIGURATION.md.
