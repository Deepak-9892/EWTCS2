# ============================================================================
# EWTCS Environment Configuration Template
# ============================================================================
# Emergency Ward Tracking & Communication System
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your actual values (never commit .env.local to Git)
# 3. See DATABASE_SETUP.md for complete setup guide
# 4. See CONFIGURATION.md for advanced configuration options
#
# IMPORTANT: 
# - .env.local is already in .gitignore (DO NOT commit credentials)
# - All variables are validated on application startup
# - Use plaintext secrets in development, encrypted in production
# ============================================================================

# --------------------------------------------------------------------
# REQUIRED: Database Configuration
# --------------------------------------------------------------------
# PostgreSQL connection string - REQUIRED for all environments
#
# Format: postgresql://username:password@host:port/database
# Example: postgresql://postgres:mypassword@localhost:5432/ewtcs
#
# SPECIAL CHARACTERS: If password contains special chars, URL-encode them:
#   @ → %40    # → %23    & → %26    : → %3A    / → %2F
#
# PRODUCTION: Use DATABASE_URL_ENCRYPTED instead (see below)
DATABASE_URL=postgresql://postgres:password@localhost:5432/ewtcs

# Production-only: Encrypted database connection (recommended for production)
# Generate with: node scripts/encrypt-secret.js
# Requires ENCRYPTION_KEY (see below)
# DATABASE_URL_ENCRYPTED=ivhex:encryptedhex

# --------------------------------------------------------------------
# REQUIRED: Security Configuration
# --------------------------------------------------------------------
# Encryption key for sensitive data (32-byte minimum for production)
# Only required when using *_ENCRYPTED variables
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=your-64-character-hex-string-here

# --------------------------------------------------------------------
# REQUIRED: Application Configuration
# --------------------------------------------------------------------
# Public application URL - used for redirects, emails, and external links
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------------------------------------------------------------
# REQUIRED: Environment Selection
# --------------------------------------------------------------------
# Node environment: development | staging | production
# - development: Allows plaintext secrets, verbose logging
# - staging: Similar to production but with more lenient validation
# - production: Requires encrypted secrets, minimal logging
NODE_ENV=development

# --------------------------------------------------------------------
# OPTIONAL: Alert Configuration
# --------------------------------------------------------------------
# Threshold for "delayed" bed alerts in milliseconds
# Default: 10800000 (3 hours)
# 1 hour = 3600000
# 2 hours = 7200000
# 3 hours = 10800000 (default)
# 4 hours = 14400000
RED_ALERT_THRESHOLD_MS=10800000

# --------------------------------------------------------------------
# OPTIONAL: AI Configuration (Future Feature)
# --------------------------------------------------------------------
# OpenAI API key for AI-powered daily reports and analytics
# Leave commented if not using AI features
#
# Option A: Plaintext (development/staging only)
# OPENAI_API_KEY=sk-your-openai-api-key-here
#
# Option B: Encrypted (recommended for production)
# OPENAI_API_KEY_ENCRYPTED=ivhex:encryptedhex
# Requires ENCRYPTION_KEY (see Security Configuration above)

# ============================================================================
# QUICK START CHECKLIST
# ============================================================================
# [ ] 1. Install PostgreSQL 14 or higher
# [ ] 2. Create database: createdb ewtcs
# [ ] 3. Copy this file: cp .env.example .env.local
# [ ] 4. Update DATABASE_URL with your PostgreSQL credentials
# [ ] 5. Run migrations: npm run db:migrate
# [ ] 6. Seed database: npm run db:seed
# [ ] 7. Start server: npm run dev
# [ ] 8. Login with admin/Admin@123
#
# For detailed setup instructions, see DATABASE_SETUP.md
# ============================================================================

# --------------------------------------------------------------------
# ENVIRONMENT-SPECIFIC EXAMPLES
# --------------------------------------------------------------------
# 
# DEVELOPMENT (.env.local):
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ewtcs_dev
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NODE_ENV=development
# RED_ALERT_THRESHOLD_MS=10800000
#
# STAGING (.env.staging):
# DATABASE_URL=postgresql://user:pass@staging-host:5432/ewtcs_staging
# NEXT_PUBLIC_APP_URL=https://staging.yourdomain.com
# NODE_ENV=staging
# RED_ALERT_THRESHOLD_MS=10800000
#
# PRODUCTION (.env.production):
# DATABASE_URL_ENCRYPTED=ivhex:encryptedhex
# ENCRYPTION_KEY=your-64-character-hex-string
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
# NODE_ENV=production
# RED_ALERT_THRESHOLD_MS=10800000
#
# --------------------------------------------------------------------

# --------------------------------------------------------------------
# VALIDATION NOTES
# --------------------------------------------------------------------
# ✅ DATABASE_URL must be valid PostgreSQL connection string
# ✅ NEXT_PUBLIC_APP_URL must be valid URL
# ✅ RED_ALERT_THRESHOLD_MS must be positive integer
# ✅ Production requires DATABASE_URL_ENCRYPTED (plaintext not allowed)
# ✅ Encrypted variables require ENCRYPTION_KEY
# ✅ All required variables validated on startup
# ❌ Missing DATABASE_URL → Application will not start
# ❌ Invalid PostgreSQL URL → Application will not start
# ❌ Production without encryption → Application will not start
# --------------------------------------------------------------------

# For complete documentation:
# - Database Setup: See DATABASE_SETUP.md
# - Configuration: See CONFIGURATION.md
# - Contributing: See CONTRIBUTING.md
# - Architecture: See reports/FEATURE-FIRST-ARCHITECTURE-PLAN.md
