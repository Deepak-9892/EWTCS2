{
  "name": "ewtcs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev",
    "build": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next build",
    "start": "node scripts/run-migrations.js up && next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "setup": "node scripts/quick-start-setup.mjs",
    "db:migrate": "node scripts/run-migrations.js up",
    "db:reconcile": "node scripts/reconcile-migration-history.js",
    "audit:verify": "node scripts/verify-audit-immutability.js",
    "db:rollback": "node scripts/run-migrations.js down 1",
    "db:status": "node scripts/run-migrations.js status",
    "db:tatus": "node scripts/run-migrations.js status",
    "db:create": "node scripts/run-migrations.js create",
    "init": "node scripts/init-system.js",
    "db:seed": "node scripts/seed-genuine-data.mjs",
    "seed:config": "node scripts/seed-config.mjs",
    "db:reset": "node scripts/reset-db.js",
    "validate:env": "node scripts/validate-env-example.js",
    "validate:db": "node scripts/validate-db-connection.js",
    "validate:migrations": "node scripts/validate-migrations.js",
    "validate:schema": "node scripts/validate-db-schema.js",
    "security:ssl:check": "node scripts/check-ssl-certificate.mjs",
    "validate:all": "npm run validate:env && npm run validate:db && npm run validate:migrations && npm run validate:schema && npm run build",
    "perf:seed": "node scripts/seed-realistic-performance-volume.js",
    "perf:check": "node scripts/run-performance-gate.js",
    "perf:validate": "npm run perf:seed && npm run perf:check",
    "backup:run": "node scripts/db-backup.mjs",
    "backup:verify": "node scripts/db-backup-verify.mjs",
    "backup:restore": "node scripts/db-restore.mjs",
    "backup:setup": "node scripts/setup-backup-cron.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bcrypt": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "dotenv": "^16.4.7",
    "framer-motion": "^12.34.3",
    "html2canvas": "^1.4.1",
    "jose": "^6.1.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.564.0",
    "next": "^15.1.12",
    "next-themes": "^0.4.6",
    "node-pg-migrate": "^8.0.4",
    "nprogress": "^0.2.0",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/html2canvas": "^0.5.35",
    "@types/node": "^20",
    "@types/nprogress": "^0.2.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.20.0",
    "eslint-config-next": "^15.1.7",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@eslint-community/eslint-utils": "^4.4.1",
    "minimatch": ">=10.2.1",
    "@eslint/eslintrc": {
      "minimatch": "^3.1.4"
    }
