# Staging Environment
DATABASE_URL=postgresql://username:password@staging-db.example.com:5432/ewtcs_staging
SESSION_SECRET=staging-secret-key-change-in-production-min-32-chars
NEXT_PUBLIC_APP_URL=https://staging.ewtcs.example.com
FORCE_HTTPS=true
PORT=3000
NODE_ENV=staging
RED_ALERT_THRESHOLD_MS=10800000
NEXT_PUBLIC_REALTIME_ENABLED=true
NEXT_PUBLIC_REALTIME_POLLING_INTERVAL_MS=3000
NEXT_PUBLIC_REALTIME_RETRY_INTERVAL_MS=10000
NEXT_PUBLIC_REALTIME_MAX_RETRY_INTERVAL_MS=30000
