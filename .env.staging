# Staging Environment Configuration
# Replace placeholders with actual staging values.

# PostgreSQL Database Configuration
DATABASE_URL=postgresql://username:password@staging-db.example.com:5432/ewtcs_staging

# Application URL
NEXT_PUBLIC_APP_URL=https://staging.ewtcs.example.com

# Node Environment
NODE_ENV=staging

# Alert Threshold (milliseconds)
RED_ALERT_THRESHOLD_MS=10800000

# Optional: OpenAI API Key
# OPENAI_API_KEY=staging_api_key_here

# Optional: Encrypted secrets (recommended for staging)
# DATABASE_URL_ENCRYPTED=ivhex:encryptedhex
# OPENAI_API_KEY_ENCRYPTED=ivhex:encryptedhex
# ENCRYPTION_KEY=your-32-byte-master-key
