# Production Environment
# IMPORTANT: Always use encrypted secrets in production
# DATABASE_URL_ENCRYPTED=ivhex:encryptedhex
# SESSION_SECRET=production-secret-key-min-64-chars-really-strong
# ENCRYPTION_KEY=your-64-char-hex-key-for-decryption
NEXT_PUBLIC_APP_URL=https://your-production-domain.com
FORCE_HTTPS=true
HSTS_PRELOAD=false
PORT=3000
NODE_ENV=production
RED_ALERT_THRESHOLD_MS=10800000
NEXT_PUBLIC_REALTIME_ENABLED=true
NEXT_PUBLIC_REALTIME_POLLING_INTERVAL_MS=3000
NEXT_PUBLIC_REALTIME_RETRY_INTERVAL_MS=10000
NEXT_PUBLIC_REALTIME_MAX_RETRY_INTERVAL_MS=30000
# OPENAI_API_KEY_ENCRYPTED=ivhex:encryptedhex
