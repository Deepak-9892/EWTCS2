# Production Environment Configuration
# WARNING: This file is for reference only.
# Never commit production credentials to git.
# Use proper secret management (AWS Secrets Manager, Vault, etc.).

# PostgreSQL Database Configuration
# In production, use encrypted secrets.
# DATABASE_URL is not allowed in production by the config validator.
# DATABASE_URL_ENCRYPTED is required.
DATABASE_URL_ENCRYPTED=ivhex:encryptedhex
ENCRYPTION_KEY=your-32-byte-master-key

# Application URL
NEXT_PUBLIC_APP_URL=https://ewtcs.example.com

# Node Environment
NODE_ENV=production

# Alert Threshold (milliseconds)
RED_ALERT_THRESHOLD_MS=10800000

# Optional: Encrypted OpenAI API Key
# OPENAI_API_KEY_ENCRYPTED=ivhex:encryptedhex

# Production Security Checklist:
# 1. Use environment variables from containerization (Docker, Kubernetes).
# 2. Never commit real credentials.
# 3. Use secret management tools (AWS Secrets Manager, Vault).
# 4. Rotate credentials regularly.
# 5. Enable audit logging for configuration access.
# 6. Use HTTPS/TLS for all communications.
# 7. Monitor database connections and queries.
# 8. Set alerts for configuration changes.
